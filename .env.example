# .env.example
# Copy this to .env and fill in your values. .env is gitignored so your
# host and path are never committed to the repository.

# deploy.sh: SSH target and root directory of the Minecraft server.
# SSH_HOST is the user@host you would pass to ssh/scp.
# SERVER_DIR is the parent folder that contains server.properties and
# the world directory. The script reads the world name automatically
# from server.properties so you do not need to specify it here.
SSH_HOST="user@hostname"
SERVER_DIR="/path/to/minecraft/server"

# Legacy Pastebin key -- no longer used by deploy.sh, kept for reference only.
# PASTEBIN_API_KEY="your_key_here"